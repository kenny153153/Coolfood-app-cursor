# Copy this file to .env.local and fill in your values.
# Required for Supabase (local dev). Vercel uses dashboard env vars.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase URL (API routes). If not set, falls back to VITE_SUPABASE_URL.
# SUPABASE_URL=https://your-project.supabase.co

# Optional (Google Maps is client-side)
VITE_GOOGLE_MAPS_API_KEY=

# Vertex AI (Paid Tier) — paste your service account JSON as a single line
# Also set in Vercel dashboard (NOT prefixed with VITE_)
GOOGLE_VERTEX_AI_CREDENTIALS=

# Stripe (payment processing). Server-side only — do NOT prefix with VITE_.
# Test mode: use sk_test_... key from Stripe Dashboard → Developers → API keys.
# Production: use sk_live_... key and set STRIPE_ENV=prod.
# Set STRIPE_SECRET_KEY in Vercel Dashboard → Settings → Environment Variables.
STRIPE_SECRET_KEY=

# Stripe Webhook signing secret (Dashboard → Developers → Webhooks → select endpoint → Signing secret).
# Required for POST /api/webhooks/stripe (checkout.session.completed). Server-side only — do NOT use VITE_.
STRIPE_WEBHOOK_SECRET=

# Optional: when running npm run dev, /api is proxied to this URL. Default: coolfood-app-cursor.vercel.app
# VITE_API_PROXY_TARGET=https://your-deployment.vercel.app

# 順豐 SF Express 沙箱（api/sf-order、confirm-payment 用）
# 在 Vercel 設定：SF_PARTNER_ID、SF_CHECKWORD、SF_SENDER_NAME、SF_SENDER_PHONE、SF_SENDER_ADDRESS
# SF_PARTNER_ID=你的顧客編碼
# SF_CHECKWORD=你的校驗碼
# SF_ENV=demo # demo/sandbox/prod
# SF_MONTHLY_CARD=你的月結卡號
# SF_HOME_EXPRESS_TYPE_ID=273
# SF_LOCKER_EXPRESS_TYPE_ID=274
# SF_COLD_EXPRESS_TYPE_ID=201
# SF_SENDER_NAME=寄件人姓名
# SF_SENDER_PHONE=寄件人電話
# SF_SENDER_ADDRESS=寄件人地址
# SF_CLOUD_PRINT_TEMPLATE_CODE=fm_150_standard_你的客戶編碼

# Ultramsg WhatsApp (server-side only, set in Vercel)
# ULTRAMSG_INSTANCE_ID=your-instance-id
# ULTRAMSG_TOKEN=your-token

# Supabase 服務端 — REQUIRED for admin login, payment confirmation, SF Express
# Find it in Supabase Dashboard → Settings → API → service_role key
# Set in Vercel: Dashboard → Settings → Environment Variables (do NOT prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Internal API secret — REQUIRED for server-to-server calls (e.g. confirm-payment → SF).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this in Vercel AND .env.local — internal calls will fail without it.
INTERNAL_API_SECRET=

# Webhook secret — used to verify Supabase webhook calls to /api/on-order-paid
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value in Supabase Dashboard → Database → Webhooks → HTTP Headers: x-webhook-secret
WEBHOOK_SECRET=

# (Airwallex keys removed — migrated to Stripe. See STRIPE_SECRET_KEY above.)

# ── Sentry (error monitoring) ──────────────────────────────────────
# Create a project at https://sentry.io → Settings → Projects → Client Keys (DSN)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Upstash Redis (rate limiting — optional, falls back to in-memory) ─
# Create free DB at https://upstash.com → Redis → copy REST URL + token
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ── Environment ────────────────────────────────────────────────────
# For staging/production separation on Vercel:
#   1. Create two Vercel projects (or use Preview vs Production environments)
#   2. Set separate Supabase projects + env vars for each
#   3. Set VITE_APP_ENV to 'staging' or 'production' accordingly
# VITE_APP_ENV=production
